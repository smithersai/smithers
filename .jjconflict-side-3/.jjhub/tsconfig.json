{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "smithers-orchestrator",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noImplicitAny": false,
    "types": ["bun-types"],
    "paths": {
      "smithers-orchestrator": ["../src/index.ts"],
      "smithers-orchestrator/*": ["../src/*"]
    }
  },
  "include": ["workflows/**/*.tsx"]
}
