{
  "name": "@smithers/observability",
  "version": "0.0.0",
  "description": "Concrete Smithers metrics, logging, tracing, and observability integrations",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./metrics": {
      "types": "./src/index.d.ts",
      "import": "./src/metrics/index.js",
      "default": "./src/metrics/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/agents": "workspace:*",
    "@smithers/driver": "workspace:*",
    "effect": "^3.21.0",
    "@effect/opentelemetry": "^0.61.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
