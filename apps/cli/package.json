{
  "name": "@smithers/cli",
  "version": "0.0.0",
  "description": "Smithers command-line interface, TUI, MCP server, and local workflow tools",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "bin": {
    "smithers": "./src/index.ts"
  },
  "dependencies": {
    "smithers": "workspace:*",
    "@smithers/server": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/time-travel": "workspace:*",
    "@smithers/agents": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "incur": "^0.3.3",
    "@opentui/core": "^0.1.92",
    "@opentui/react": "^0.1.92",
    "picocolors": "^1.1.1",
    "react": "^18.3.0 || ^19.0.0",
    "zod": "^4.3.6",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/scheduler": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
