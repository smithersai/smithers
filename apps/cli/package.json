{
  "name": "@smithers/cli",
  "version": "0.0.0",
  "description": "Smithers command-line interface, TUI, MCP server, and local workflow tools",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsup --dts-only"
  },
  "bin": {
    "smithers": "./src/index.js"
  },
  "dependencies": {
    "@effect/workflow": "^0.18.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@opentui/core": "^0.1.92",
    "@opentui/react": "^0.1.92",
    "@smithers/agents": "workspace:*",
    "@smithers/components": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "@smithers/server": "workspace:*",
    "@smithers/time-travel": "workspace:*",
    "effect": "^3.21.0",
    "incur": "^0.3.3",
    "picocolors": "^1.1.1",
    "react": "^18.3.0 || ^19.0.0",
    "smithers-orchestrator": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
