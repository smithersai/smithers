imports:
  workflows[1]{from,as}:
    ./toon-subworkflow.toon,research
name: toon-workflow-import
input:
  topic: string
steps[2]:
  - id: do_research
    kind: workflow
    use: research
    input:
      topic: "{input.topic}"
  - id: report
    needs[1]: do_research
    run: "return { report: `Report: ${do_research.summary}` };\n"
    output:
      report: string
