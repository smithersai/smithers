imports:
  workflows:
    - from: "./toon-subworkflow.toon"
      as: research

name: toon-workflow-import

input:
  topic: string

steps:
  - id: do_research
    kind: workflow
    use: research
    input:
      topic: "{input.topic}"

  - id: report
    needs: [do_research]
    run: |
      return { report: `Report: ${do_research.summary}` };
    output:
      report: string
