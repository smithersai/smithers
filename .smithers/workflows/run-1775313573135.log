rsePositiveInt(value: string | null, fallback: number): number {\n    70→  if (value === null) return fallback;\n    71→  const num = Number(value);\n    72→  if (!Number.isFinite(num) || num <= 0) {\n    73→    throw new HttpError(\n    74→      400,\n    75→      \"INVALID_REQUEST\",\n    76→      `Expected a positive integer, got \"${value}\"`,\n    77→    );\n    78→  }\n    79→  return Math.floor(num);\n    80→}\n    81→\n    82→function parseOptionalInt(value: string | null, fallback: number): number {\n    83→  if (value === null) return fallback;\n    84→  const num = Number(value);\n    85→  if (!Number.isFinite(num)) {\n    86→    throw new HttpError(\n    87→      400,\n    88→      \"INVALID_REQUEST\",\n    89→      `Expected a number, got \"${value}\"`,\n    90→    );\n    91→  }\n    92→  return Math.floor(num);\n    93→}\n    94→\n    95→async function readBody(req: IncomingMessage, maxBytes: number): Promise<any> {\n    96→  const chunks: Buffer[] = [];\n    97→  let total = 0;\n    98→  const lengthHeader = req.headers[\"content-length\"];\n    99→  if (lengthHeader) {\n   100→    const len = Array.isArray(lengthHeader)\n   101→      ? Number(lengthHeader[0])\n   102→      : Number(lengthHeader);\n   103→    if (Number.isFinite(len) && len > maxBytes) {\n   104→      throw new HttpError(\n   105→        413,\n   106→        \"PAYLOAD_TOO_LARGE\",\n   107→        `Request body exceeds ${maxBytes} bytes`,\n   108→        { maxBytes },\n   109→      );\n   110→    }\n   111→  }\n   112→  for await (const chunk of req) {\n   113→    const buf = Buffer.from(chunk);\n   114→    total += buf.length;\n   115→    if (total > maxBytes) {\n   116→      throw new HttpError(\n   117→        413,\n   118→        \"PAYLOAD_TOO_LARGE\",\n   119→        `Request body exceeds ${maxBytes} bytes`,\n   120→        { maxBytes },\n   121→      );\n   122→    }\n   123→    chunks.push(buf);\n   124→  }\n   125→  const body = Buffer.concat(chunks).toString(\"utf8\");\n   126→  if (!body) return {};\n   127→  try {\n   128→    return JSON.parse(body);\n   129→  } catch (err: any) {\n   130→    throw new HttpError(\n   131→      400,\n   132→      \"INVALID_JSON\",\n   133→      err?.message ?? \"Request body must be valid JSON\",\n   134→    );\n   135→  }\n   136→}\n   137→\n   138→async function loadWorkflow(absPath: string): Promise<SmithersWorkflow<any>> {\n   139→  const source = await readFile(absPath);\n   140→  const version = createHash(\"sha1\").update(source).digest(\"hex\");\n   141→  const extIdx = absPath.lastIndexOf(\".\");\n   142→  const ext = extIdx >= 0 ? absPath.slice(extIdx) : \"\";\n   143→  const base = basename(absPath, ext);\n   144→  const shadowPath = resolve(dirname(absPath), `.${base}.smithers-${version}${ext}`);\n   145→  await writeFile(shadowPath, source);\n   146→  const mod = await import(pathToFileURL(shadowPath).href);\n   147→  if (!mod.default) throw new SmithersError(\"WORKFLOW_MISSING_DEFAULT\", \"Workflow must export default\");\n   148→  return mod.default as SmithersWorkflow<any>;\n   149→}\n   150→total 104\ndrwxr-xr-x@  4 williamcory  staff    128 Apr  3 20:33 .\ndrwxr-xr-x@ 60 williamcory  staff   1920 Apr  3 20:33 ..\n-rw-r--r--@  1 williamcory  staff  37011 Apr  3 20:33 index.ts\n-rw-r--r--@  1 williamcory  staff   8747 Apr  3 20:33 serve.ts     1→import { Hono } from \"hono\";\n     2→import { streamSSE } from \"hono/streaming\";\n     3→import { Metric } from \"effect\";\n     4→import type { SmithersWorkflow } from \"../SmithersWorkflow\";\n     5→import { SmithersDb } from \"../db/adapter\";\n     6→import { approveNode, denyNode } from \"../engine/approvals\";\n     7→import { isRunHeartbeatFresh } from \"../engine\";\n     8→import { nowMs } from \"../utils/time\";\n     9→import {\n    10→  prometheusContentType,\n    11→  renderPrometheusMetrics,\n    12→} from \"../observability\";\n    13→import { runPromise } from \"../effect/runtime\";\n    14→import { httpRequests, httpRequestDuration, trackEvent } from \"../effect/metrics\";\n    15→\n    16→export type ServeOptions = {\n    17→  workflow: SmithersWorkflow<any>;\n    18→  adapter: SmithersDb;\n    19→  runId: string;\n    20→  abort: AbortController;\n    21→  authToken?: string;\n    22→  metrics?: boolean;\n    23→};\n    24→\n    25→type HttpErrorCode =\n    26→  | \"UNAUTHORIZED\"\n    27→  | \"RUN_NOT_FOUND\"\n    28→  | \"RUN_NOT_ACTIVE\"\n    29→  | \"NOT_FOUND\"\n    30→  | \"SERVER_ERROR\"\n    31→  | \"INVALID_REQUEST\";\n    32→\n    33→class HttpError extends Error {\n    34→  status: number;\n    35→  code: HttpErrorCode;\n    36→  constructor(status: number, code: HttpErrorCode, message: string) {\n    37→    super(message);\n    38→    this.status = status;\n    39→    this.code = code;\n    40→  }\n    41→}\n    42→\n    43→export function createServeApp(opts: ServeOptions) {\n    44→  const { adapter, runId, abort, authToken, metrics: metricsEnabled = true } = opts;\n    45→  const app = new Hono();\n    46→\n    47→  // Health — no auth\n    48→  app.get(\"/health\", (c) => c.json({ ok: true }));\n    49→\n    50→  // Auth middleware — applied after /health\n    51→  if (authToken) {\n    52→    app.use(\"*\", async (c, next) => {\n    53→      // /health already matched above, so this won't fire for it\n    54→      const smithersKey = c.req.header(\"x-smithers-key\");\n    55→      if (smithersKey === authToken) return next();\n    56→\n    57→      const authHeader = c.req.header(\"authorization\");\n    58→      if (authHeader) {\n    59→        const token = authHeader.startsWith(\"Bearer \")\n    60→          ? authHeader.slice(7)\n    61→          : authHeader;\n    62→        if (token === authToken) return next();\n    63→      }\n    64→\n    65→      return c.json(\n    66→        { error: { code: \"UNAUTHORIZED\", message: \"Missing or invalid authorization token\" } },\n    67→        401,\n    68→      );\n    69→    });\n    70→  }\n    71→\n    72→  // Timing middleware\n    73→  app.use(\"*\", async (c, next) => {\n    74→    const start = performance.now();\n    75→    await next();\n    76→    void runPromise(Metric.update(httpRequestDuration, performance.now() - start));\n    77→    void runPromise(Metric.increment(httpRequests));\n    78→  });\n    79→\n    80→  // GET / — run status\n    81→  app.get(\"/\", async (c) => {\n    82→    const run = await adapter.getRun(runId);\n    83→    if (!run) {\n    84→      throw new HttpError(404, \"RUN_NOT_FOUND\", \"Run not found\");\n    85→    }\n    86→    const summary = await adapter.countNodesByState(runId);\n    87→    return c.json({\n    88→      runId,\n    89→      workflowName: run.workflowName ?? \"workflow\",\n    90→      status: run.status ?? \"unknown\",\n    91→      startedAtMs: run.startedAtMs ?? null,\n    92→      finishedAtMs: run.finishedAtMs ?? null,\n    93→      summary: (summary as any[]).reduce((acc: any, row: any) => {\n    94→        acc[row.state] = row.count;\n    95→        return acc;\n    96→      }, {}),\n    97→    });\n    98→  });\n    99→\n   100→  // GET /events — SSE stream\n   101→  app.get(\"/events\", (c) => {\n   102→    const afterSeqParam = c.req.query(\"afterSeq\");\n   103→    let lastSeq = afterSeqParam ? parseInt(afterSeqParam, 10) : -1;\n   104→    if (!Number.isFinite(lastSeq)) lastSeq = -1;\n   105→\n   106→    return streamSSE(c, async (stream) => {\n   107→      let closed = false;\n   108→\n   109→      // Use the abort signal from the request to detect disconnects\n   110→      c.req.raw.signal.addEventListener(\"abort\", () => {\n   111→        closed = true;\n   112→      });\n   113→\n   114→      while (!closed) {\n   115→        const events = await adapter.listEvents(runId, lastSeq, 200);\n   116→        for (const ev of events as any[]) {\n   117→          lastSeq = ev.seq;\n   118→          await stream.writeSSE({\n   119→            event: \"smithers\",\n   120→            data: ev.payloadJson,\n   121→            id: String(ev.seq),\n   122→          });\n   123→        }\n   124→\n   125→        // Check if run is terminal\n   126→        const runRow = await adapter.getRun(runId);\n   127→        if (\n   128→          runRow &&\n   129→          [\"finished\", \"failed\", \"cancelled\", \"continued\"].includes(runRow.status) &&\n   130→          (events as any[]).length === 0\n   131→        ) {\n   132→          break;\n   133→        }\n   134→\n   135→        await new Promise((r) => setTimeout(r, 500));\n   136→      }\n   137→    });\n   138→  });\n   139→\n   140→  // GET /frames\n   141→  app.get(\"/frames\", async (c) => {\n   142→    const limitParam = c.req.query(\"limit\");\n   143→    const limit = limitParam ? Math.max(1, parseInt(limitParam, 10) || 50) : 50;\n   144→    const afterParam = c.req.query(\"afterFrameNo\");\n   145→    const afterFrameNo =\n   146→      afterParam !== null && afterParam !== undefined\n   147→        ? parseInt(afterParam, 10)\n   148→        : undefined;\n   149→\n   150→    const frames = await adapter.listFrames(\n   151→      runId,\n   152→      limit,\n   153→      afterFrameNo !== undefined && Number.isFinite(afterFrameNo) && afterFrameNo >= 0\n   154→        ? afterFrameNo\n   155→        : undefined,\n   156→    );\n   157→    return c.json(frames);\n   158→  });\n   159→\n   160→  // POST /approve/:nodeId\n   161→  app.post(\"/approve/:nodeId\", async (c) => {\n   162→    const nodeId = c.req.param(\"nodeId\");\n   163→    const body = await c.req.json().catch(() => ({}));\n   164→    await approveNode(\n   165→      adapter,\n   166→      runId,\n   167→      nodeId,\n   168→      body.iteration ?? 0,\n   169→      body.note,\n   170→      body.decidedBy,\n   171→    );\n   172→    return c.json({ runId });\n   173→  });\n   174→\n   175→  // POST /deny/:nodeId\n   176→  app.post(\"/deny/:nodeId\", async (c) => {\n   177→    const nodeId = c.req.param(\"nodeId\");\n   178→    const body = await c.req.json().catch(() => ({}));\n   179→    await denyNode(\n   180→      adapter,\n   181→      runId,\n   182→      nodeId,\n   183→      body.iteration ?? 0,\n   184→      body.note,\n   185→      body.decidedBy,\n   186→    );\n   187→    return c.json({ runId });\n   188→  });\n   189→\n   190→  // POST /cancel\n   191→  app.post(\"/cancel\", async (c) => {\n   192→    const run = await adapter.getRun(runId);\n   193→    if (!run) {\n   194→      throw new HttpError(404, \"RUN_NOT_FOUND\", \"Run not found\");\n   195→    }\n   196→\n   197→    if (run.status === \"waiting-approval\" || run.status === \"waiting-timer\") {\n   198→      const cancelledAtMs = nowMs();\n   199→      const cancelEvent = {\n   200→        type: \"RunCancelled\" as const,\n   201→        runId,\n   202→        timestampMs: cancelledAtMs,\n   203→      };\n   204→      if (run.status === \"waiting-timer\") {\n   205→        const nodes = await adapter.listNodes(runId);\n   206→        for (const node of (nodes as any[]).filter((entry) => entry.state === \"waiting-timer\")) {\n   207→          const attempts = await adapter.listAttempts(runId, node.nodeId, node.iteration ?? 0);\n   208→          const waitingAttempt = (attempts as any[]).find((attempt) => attempt.state === \"waiting-timer\");\n   209→          if (!waitingAttempt) continue;\n   210→          await adapter.updateAttempt(\n   211→            runId,\n   212→            node.nodeId,\n   213→            node.iteration ?? 0,\n   214→            waitingAttempt.attempt,\n   215→            { state: \"cancelled\", finishedAtMs: cancelledAtMs },\n   216→          );\n   217→          await adapter.insertNode({\n   218→            runId,\n   219→            nodeId: node.nodeId,\n   220→            iteration: node.iteration ?? 0,\n   221→            state: \"cancelled\",\n   222→            lastAttempt: waitingAttempt.attempt,\n   223→            updatedAtMs: cancelledAtMs,\n   224→            outputTable: node.outputTable ?? \"\",\n   225→            label: node.label ?? null,\n   226→          });\n   227→          const timerCancelledEvent = {\n   228→            type: \"TimerCancelled\" as const,\n   229→            runId,\n   230→            timerId: node.nodeId,\n   231→            timestampMs: cancelledAtMs,\n   232→          };\n   233→          await adapter.insertEventWithNextSeq({\n   234→            runId,\n   235→            timestampMs: cancelledAtMs,\n   236→            type: \"TimerCancelled\",\n   237→            payloadJson: JSON.stringify(timerCancelledEvent),\n   238→          });\n   239→          await runPromise(trackEvent(timerCancelledEvent));\n   240→        }\n   241→      }\n   242→      await adapter.updateRun(runId, {\n   243→        status: \"cancelled\",\n   244→        finishedAtMs: cancelledAtMs,\n   245→        heartbeatAtMs: null,\n   246→        runtimeOwnerId: null,\n   247→        cancelRequestedAtMs: null,\n   248→      });\n   249→      await adapter.insertEventWithNextSeq({\n   250→        runId,\n   251→        timestampMs: cancelledAtMs,\n   252→        type: \"RunCancelled\",\n   253→        payloadJson: JSON.stringify(cancelEvent),\n   254→      });\n   255→      await runPromise(trackEvent(cancelEvent));\n   256→      return c.json({ runId });\n   257→    }\n   258→\n   259→    if (run.status !== \"running\" || !isRunHeartbeatFresh(run)) {\n   260→      throw new HttpError(409, \"RUN_NOT_ACTIVE\", \"Run is not currently active\");\n   261→    }\n   262→\n   263→    await adapter.requestRunCancel(runId, nowMs());\n   264→    abort.abort();\n   265→    return c.json({ runId });\n   266→  });\n   267→\n   268→  // GET /metrics\n   269→  if (metricsEnabled) {\n   270→    app.get(\"/metrics\", (c) => {\n   271→      return c.text(renderPrometheusMetrics(), 200, {\n   272→        \"Content-Type\": prometheusContentType,\n   273→      });\n   274→    });\n   275→  }\n   276→\n   277→  // 404 catch-all\n   278→  app.notFound((c) => {\n   279→    return c.json(\n   280→      { error: { code: \"NOT_FOUND\", message: \"Route not found\" } },\n   281→      404,\n   282→    );\n   283→  });\n   284→\n   285→  // Error handler\n   286→  app.onError((err, c) => {\n   287→    if (err instanceof HttpError) {\n   288→      return c.json(\n   289→        { error: { code: err.code, message: err.message } },\n   290→        err.status as any,\n   291→      );\n   292→    }\n   293→    return c.json(\n   294→      { error: { code: \"SERVER_ERROR\", message: err.message ?? \"Unknown error\" } },\n   295→      500,\n   296→    );\n   297→  });\n   298→\n   299→  return app;\n   300→}\n   301→total 248\ndrwxr-xr-x@ 11 williamcory  staff    352 Apr  3 21:38 .\ndrwxr-xr-x@ 60 williamcory  staff   1920 Apr  3 20:33 ..\n-rw-r--r--@  1 williamcory  staff  53352 Apr  3 21:38 adapter.ts\n-rw-r--r--@  1 williamcory  staff  11066 Apr  3 20:33 ensure.ts\n-rw-r--r--@  1 williamcory  staff   9922 Apr  3 20:33 frame-codec.ts\n-rw-r--r--@  1 williamcory  staff    459 Apr  2 21:20 input.ts\n-rw-r--r--@  1 williamcory  staff   6929 Apr  3 20:33 internal-schema.ts\n-rw-r--r--@  1 williamcory  staff   8969 Apr  2 21:20 output.ts\n-rw-r--r--@  1 williamcory  staff    766 Mar 29 11:11 schema-signature.ts\n-rw-r--r--@  1 williamcory  staff   4485 Mar 29 11:11 snapshot.ts\n-rw-r--r--@  1 williamcory  staff   4830 Apr  3 21:06 write-retry.ts     1→import type { BunSQLiteDatabase } from \"drizzle-orm/bun-sqlite\";\n     2→import { Effect } from \"effect\";\n     3→import { fromSync } from \"../effect/interop\";\n     4→import { runSync } from \"../effect/runtime\";\n     5→import { SmithersError } from \"../utils/errors\";\n     6→\n     7→export function ensureSmithersTablesEffect(\n     8→  db: BunSQLiteDatabase<any>,\n     9→): Effect.Effect<void, SmithersError> {\n    10→  const client: any = (db as any).$client;\n    11→  if (!client || typeof client.exec !== \"function\") {\n    12→    throw new SmithersError(\n    13→      \"DB_REQUIRES_BUN_SQLITE\",\n    1