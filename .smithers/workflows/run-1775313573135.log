e frame encoding.\n   302→    const frameColumns = yield* fromSync(\n   303→      \"inspect _smithers_frames columns\",\n   304→      () =>\n   305→        client\n   306→          .query(`PRAGMA table_info(\"_smithers_frames\")`)\n   307→          .all() as { name: string }[],\n   308→      { code: \"DB_QUERY_FAILED\" },\n   309→    );\n   310→    const hasEncodingColumn = frameColumns.some((col) => col.name === \"encoding\");\n   311→    if (!hasEncodingColumn) {\n   312→      yield* Effect.either(\n   313→        fromSync(\n   314→          \"add frame encoding column\",\n   315→          () =>\n   316→            client.run(\n   317→              `ALTER TABLE _smithers_frames ADD COLUMN encoding TEXT NOT NULL DEFAULT 'full'`,\n   318→            ),\n   319→          { code: \"DB_WRITE_FAILED\" },\n   320→        ),\n   321→      );\n   322→    }\n   323→  }).pipe(Effect.withLogSpan(\"db:ensure-smithers-tables\"));\n   324→}\n   325→\n   326→export function ensureSmithersTables(db: BunSQLiteDatabase<any>): void {\n   327→  runSync(ensureSmithersTablesEffect(db));\n   328→}\n   329→     1→# Replace GitHub OAuth with WorkOS\n     2→\n     3→**Repo:** plue (JJHub Go backend)\n     4→**Feature:** Authentication\n     5→**Priority:** P0 — blocks everything\n     6→\n     7→## Description\n     8→\n     9→Replace the existing custom GitHub OAuth flow in `internal/auth/` and `internal/routes/auth.go` with WorkOS SDK. WorkOS handles the GitHub OAuth consent screen, token exchange, and session management.\n    10→\n    11→## Acceptance Criteria\n    12→\n    13→- [ ] WorkOS Go SDK integrated (`github.com/workos/workos-go`)\n    14→- [ ] `GET /auth/workos/authorize` redirects to WorkOS-hosted GitHub OAuth\n    15→- [ ] `GET /auth/workos/callback` exchanges WorkOS code for session, issues Smithers JWT\n    16→- [ ] JWT stored in `~/.config/smithers/auth.json` by CLI\n    17→- [ ] Existing key-based auth (`internal/auth/key_auth.go`) removed or gated\n    18→- [ ] Linear OAuth removed or gated behind `integrations` feature flag\n    19→- [ ] Old GitHub OAuth routes removed\n    20→\n    21→## E2E Test\n    22→\n    23→```\n    24→1. smithers auth login → opens browser → completes OAuth → token stored locally\n    25→2. smithers auth status → shows username, email, expiry\n    26→3. smithers auth logout → token deleted\n    27→4. smithers auth status → shows \"not logged in\"\n    28→5. API call without token → 401\n    29→```\n    30→\n    31→## Reference Code\n    32→\n    33→- Current auth: `internal/routes/auth.go`, `internal/auth/`\n    34→- WorkOS Go SDK: https://github.com/workos/workos-go\n    35→     1→# Enforce Waitlist/Whitelist on Auth\n     2→\n     3→**Repo:** plue (JJHub Go backend)\n     4→**Feature:** Authentication\n     5→**Priority:** P0 — blocks onboarding\n     6→\n     7→## Description\n     8→\n     9→After WorkOS auth succeeds, check the user's GitHub identity against the existing `alpha_whitelist_entries` table. If not whitelisted, check `alpha_waitlist_entries`. If not on either, create a waitlist entry with `status: pending`. Return appropriate errors.\n    10→\n    11→## Acceptance Criteria\n    12→\n    13→- [ ] Auth flow checks `alpha_whitelist_entries` after WorkOS callback\n    14→- [ ] Whitelisted user → JWT issued, login succeeds\n    15→- [ ] Waitlisted user with `status: approved` → promoted to whitelist, JWT issued\n    16→- [ ] Waitlisted user with `status: pending` → 403 `NOT_ON_WAITLIST`\n    17→- [ ] Unknown user → new waitlist entry created, 403 `NOT_ON_WAITLIST`\n    18→- [ ] Waitlist entries store GitHub username, email, avatar URL\n    19→\n    20→## E2E Test\n    21→\n    22→```\n    23→1. User NOT on whitelist → smithers auth login → 403 \"Your account is not yet approved\"\n    24→2. Admin adds user to whitelist via DB/API\n    25→3. User → smithers auth login → success\n    26→```\n    27→\n    28→## Reference Code\n    29→\n    30→- Existing alpha access: `internal/services/alpha_access.go`\n    31→- Auth service: `internal/services/auth.go`\n    32→(Bash completed with no output)total 0\ndrwxr-xr-x@  4 williamcory  staff   128 Apr  3 20:47 .\ndrwxr-xr-x@ 44 williamcory  staff  1408 Apr  4 07:39 ..\ndrwxr-xr-x@  6 williamcory  staff   192 Apr  3 20:47 cli\ndrwxr-xr-x@  4 williamcory  staff   128 Apr  3 20:33 webtotal 128\ndrwxr-xr-x@ 12 williamcory  staff   384 Apr  3 20:51 .\ndrwxr-xr-x@  6 williamcory  staff   192 Apr  3 20:47 ..\n-rw-r--r--@  1 williamcory  staff  3749 Apr  3 20:51 args.test.ts\n-rw-r--r--@  1 williamcory  staff  8890 Apr  3 20:51 args.ts\n-rwxr-xr-x@  1 williamcory  staff  4512 Apr  3 20:51 bin.ts\n-rw-r--r--@  1 williamcory  staff  1952 Apr  3 20:51 daemon.ts\n-rw-r--r--@  1 williamcory  staff   706 Apr  3 20:51 paths.test.ts\n-rw-r--r--@  1 williamcory  staff   591 Apr  3 20:51 paths.ts\n-rw-r--r--@  1 williamcory  staff  2319 Apr  3 20:51 ui.test.ts\n-rw-r--r--@  1 williamcory  staff  8790 Apr  3 20:51 ui.ts\n-rw-r--r--@  1 williamcory  staff  2144 Apr  3 20:51 usage.ts\n-rw-r--r--@  1 williamcory  staff  4316 Apr  3 20:51 web.ts\n---\ntotal 0\ndrwxr-xr-x@ 4 williamcory  staff  128 Apr  3 20:33 .\ndrwxr-xr-x@ 4 williamcory  staff  128 Apr  3 20:47 ..\ndrwxr-xr-x@ 3 williamcory  staff   96 Apr  2 21:54 node_modules\ndrwxr-xr-x@ 4 williamcory  staff  128 Apr  3 20:33 srctotal 0\ndrwxr-xr-x@  5 williamcory  staff   160 Apr  3 20:44 .\ndrwxr-xr-x@ 44 williamcory  staff  1408 Apr  4 07:39 ..\ndrwxr-xr-x@  3 williamcory  staff    96 Feb 12 06:45 core\ndrwxr-xr-x@  3 williamcory  staff    96 Apr  3 20:44 shared\ndrwxr-xr-x@  3 williamcory  staff    96 Feb 12 06:45 ui/Users/williamcory/smithers/src/cli/index.ts:  authToken: z.string().optional().describe(\"Bearer token for HTTP auth (or set SMITHERS_API_KEY)\"),\n/Users/williamcory/smithers/src/cli/index.ts:      if (options.authToken) childArgs.push(\"--auth-token\", options.authToken);\n/Users/williamcory/smithers/src/cli/index.ts:        authToken: options.authToken ?? process.e