214→    \"SCHEMA_REGISTRY\",\n   215→    \"CAMEL_TO_SNAKE_CONVERSION\",\n   216→  ],\n   217→  VCS_INTEGRATION: [\n   218→    \"VCS_ROOT_DETECTION\",\n   219→    \"JJ_VERSION_CONTROL_SUPPORT\",\n   220→  ],\n   221→  CROSS_CUTTING_CONCERNS: [\n   222→    \"ASPECT_CONTEXT\",\n   223→    \"ASPECTS_COMPONENT\",\n   224→    \"OUTPUT_ACCESSOR\",\n   225→    \"OUTPUT_KEY_MANAGEMENT\",\n   226→  ],\n   227→  BUILTIN_WORKFLOW_PACKS: [\n   228→    \"AUDIT_WORKFLOW\",\n   229→    \"DEBUG_WORKFLOW\",\n   230→    \"FEATURE_ENUM_WORKFLOW\",\n   231→    \"GRILL_ME_WORKFLOW\",\n   232→    \"IMPLEMENT_WORKFLOW\",\n   233→    \"IMPROVE_TEST_COVERAGE_WORKFLOW\",\n   234→    \"PLAN_WORKFLOW\",\n   235→    \"RALPH_WORKFLOW\",\n   236→    \"RESEARCH_WORKFLOW\",\n   237→    \"REVIEW_WORKFLOW\",\n   238→    \"SYNC_FEATURES_WORKFLOW\",\n   239→    \"TEST_FIRST_WORKFLOW\",\n   240→    \"TICKET_CREATE_WORKFLOW\",\n   241→    \"TICKET_IMPLEMENT_WORKFLOW\",\n   242→    \"TICKET_KANBAN_WORKFLOW\",\n   243→    \"TICKETS_BATCH_CREATE_WORKFLOW\",\n   244→    \"WRITE_A_PRD_WORKFLOW\",\n   245→  ],\n   246→  WORKFLOW_PACK_COMPONENTS: [\n   247→    \"COMMAND_PROBE_COMPONENT\",\n   248→    \"FEATURE_ENUM_COMPONENT\",\n   249→    \"FOR_EACH_FEATURE_COMPONENT\",\n   250→    \"GRILL_ME_COMPONENT\",\n   251→    \"REVIEW_COMPONENT\",\n   252→    \"VALIDATION_LOOP_COMPONENT\",\n   253→    \"WRITE_A_PRD_COMPONENT\",\n   254→  ],\n   255→} as const satisfies Record<string, readonly string[]>;\n   256→\n   257→type FeatureGroupMap = typeof FeatureGroups;\n   258→export type FeatureGroupName = keyof FeatureGroupMap;\n   259→export type FeatureName = FeatureGroupMap[FeatureGroupName][number];\n   260→\n   261→const featureEntries: Array<readonly [FeatureName, FeatureName]> = [];\n   262→\n   263→for (const group of Object.values(FeatureGroups) as readonly (readonly FeatureName[])[]) {\n   264→  for (const feature of group) {\n   265→    featureEntries.push([feature, feature] as const);\n   266→  }\n   267→}\n   268→\n   269→export const Features = Object.freeze(\n   270→  Object.fromEntries(featureEntries) as Record<FeatureName, FeatureName>,\n   271→);\n   272→total 136\ndrwxr-xr-x@ 24 williamcory  staff    768 Apr  3 20:33 .\ndrwxr-xr-x@ 44 williamcory  staff   1408 Apr  4 07:39 ..\n-rw-r--r--@  1 williamcory  staff     16 Mar 29 12:04 .mintignore\ndrwxr-xr-x@  5 williamcory  staff    160 Apr  2 21:20 api\ndrwxr-xr-x@  3 williamcory  staff     96 Apr  3 11:38 cli\ndrwxr-xr-x@ 36 williamcory  staff   1152 Apr  2 21:20 components\ndrwxr-xr-x@ 21 williamcory  staff    672 Apr  2 21:20 concepts\ndrwxr-xr-x@  9 williamcory  staff    288 Mar 29 11:32 design-prompts\n-rw-r--r--@  1 williamcory  staff   9685 Apr  3 23:17 docs.json\ndrwxr-xr-x@ 20 williamcory  staff    640 Apr  2 21:20 examples\n-rw-r--r--@  1 williamcory  staff    263 Mar 29 11:11 favicon.svg\ndrwxr-xr-x@  5 williamcory  staff    160 Mar 29 11:11 favicons\ndrwxr-xr-x@ 25 williamcory  staff    800 Apr  3 22:09 guides\ndrwxr-xr-x@  5 williamcory  staff    160 Mar 29 11:11 images\n-rw-r--r--@  1 williamcory  staff  28550 Apr  3 23:16 index.mdx\n-rw-r--r--@  1 williamcory  staff   1185 Mar 30 00:26 installation.mdx\ndrwxr-xr-x@ 12 williamcory  staff    384 Apr  2 21:20 integrations\n-rw-r--r--@  1 williamcory  staff   1892 Mar 29 11:11 introduction.mdx\ndrwxr-xr-x@  5 williamcory  staff    160 Apr  2 21:20 jsx     1→# Smithers\n     2→\n     3→**Deterministic, durable AI workflows defined as React components.**\n     4→\n     5→## What Smithers Does\n     6→\n     7→* Defines workflows as React component trees\n     8→* Executes tasks in sequence, parallel, or loops\n     9→* Persists every task result to SQLite\n    10→* Validates outputs against Zod schemas\n    11→* Re-renders the workflow after each step\n    12→* Resumes exactly where it left off after crashes\n    13→* Supports subscriptions\n    14→* Hot-reloads workflow code on file save (prompts, config, components) without restarting\n    15→\n    16→Durable execution checkpoints live in SQLite. The runtime still keeps transient process-local helpers such as file watchers, abort controllers, and active server records in memory. Every task result is stored as:\n    17→\n    18→```\n    19→(runId, nodeId, iteration) → validated output row\n    20→```\n    21→\n    22→---\n    23→\n    24→## Example\n    25→\n    26→```tsx\n    27→import { createSmithers, Sequence } from \"smithers-orchestrator\";\n    28→import { z } from \"zod\";\n    29→\n    30→const analyzeSchema = z.object({\n    31→  summary: z.string(),\n    32→  severity: z.enum([\"low\", \"medium\", \"high\"]),\n    33→});\n    34→\n    35→const fixSchema = z.object({\n    36→  patch: z.string(),\n    37→  explanation: z.string(),\n    38→});\n    39→\n    40→const { Workflow, Task, smithers, outputs } = createSmithers({\n    41→  analyze: analyzeSchema,\n    42→  fix: fixSchema,\n    43→});\n    44→\n    45→export default smithers((ctx) => (\n    46→  <Workflow name=\"bugfix\">\n    47→    <Sequence>\n    48→      <Task id=\"analyze\" output={outputs.analyze} agent={analyzer}>\n    49→        {`Analyze the bug: ${ctx.input.description}`}\n    50→      </Task>\n    51→\n    52→      <Task id=\"fix\" output={outputs.fix} agent={fixer}>\n    53→        {`Fix this issue: ${ctx.output(\"analyze\", { nodeId: \"analyze\" }).summary}`}\n    54→      </Task>\n    55→    </Sequence>\n    56→  </Workflow>\n    57→));\n    58→```\n    59→\n    60→This defines a two-stage DAG:\n    61→\n    62→```\n    63→analyze → fix\n    64→```\n    65→\n    66→After `analyze` completes:\n    67→\n    68→* Output is validated against `analyzeSchema`\n    69→* Written to SQLite\n    70→* The tree re-renders\n    71→* `fix` becomes runnable\n    72→\n    73→If the process crashes, Smithers resumes from the last completed node.\n    74→\n    75→---\n    76→\n    77→## Install\n    78→\n    79→Requires Bun ≥ 1.3.\n    80→\n    81→```bash\n    82→bun add smithers-orchestrator ai @ai-sdk/anthropic zod\n    83→```\n    84→\n    85→---\n    86→\n    87→## Mental Model\n    88→\n    89→### 1. React Tree = Execution Plan\n    90→\n    91→Your JSX tree is not UI. It is a declarative execution graph.\n    92→\n    93→* `<Workflow>` is the root.\n    94→* `<Task>` is a node.\n    95→* `<Sequence>` runs children in order.\n    96→* `<Parallel>` runs children concurrently.\n    97→* `<Ralph>` repeats children until a condition is met.\n    98→\n    99→After each task finishes, Smithers re-renders the tree with updated context.\n   100→\n   101→If new nodes are unblocked, they become runnable.\n   102→\n   103→---\n   104→\n   105→### 2. Zod Schemas = Durable Tables\n   106→\n   107→Each output schema becomes a SQLite table. Pass the schema directly to `<Task>` via the `outputs` object returned by `createSmithers`:\n   108→\n   109→```ts\n   110→const analyzeSchema = z.object({\n   111→  summary: z.string(),\n   112→  severity: z.enum([\"low\", \"medium\", \"high\"]),\n   113→});\n   114→\n   115→const { Workflow, Task, smithers, outputs } = createSmithers({\n   116→  analyze: analyzeSchema,\n   117→});\n   118→\n   119→// outputs.analyze === analyzeSchema (the ZodObject, by reference)\n   120→```\n   121→\n   122→* Agent output must validate against the schema.\n   123→* If validation fails, the task retries (with error feedback).\n   124→* Validated output is persisted.\n   125→\n   126→This makes workflows typed, inspectable, and reproducible.\n   127→\n   128→---\n   129→\n   130→### 3. Deterministic Execution\n   131→\n   132→Execution order is:\n   133→\n   134→* Depth-first\n   135→* Left-to-right\n   136→* Unblocked nodes only\n   137→\n   138→There is no hidden scheduler logic in user code.\n   139→\n   140→---\n   141→\n   142→## Core Components\n   143→\n   144→| Component    | Purpose                        |\n   145→| ------------ | ------------------------------ |\n   146→| `<Workflow>` | Root container                 |\n   147→| `<Task>`     | AI or static task node         |\n   148→| `<Sequence>` | Ordered execution              |\n   149→| `<Parallel>` | Concurrent execution           |\n   150→| `<Branch>`   | Conditional execution          |-rw-r--r--@  1 williamcory  staff   1276 Apr  4 07:40 01-auth-workos-github-oauth.md\n-rw-r--r--@  1 williamcory  staff   1184 Apr  4 07:40 02-auth-waitlist-enforcement.md(Bash completed with no output)total 0\ndrwxr-xr-x@ 4 williamcory  staff  128 Apr  3 20:33 .\ndrwxr-xr-x@ 4 williamcory  staff  128 Apr  3 20:33 ..\ndrwxr-xr-x@ 5 williamcory  staff  160 Apr  3 20:33 app\ndrwxr-xr-x@ 4 williamcory  staff  128 Apr  3 20:33 features  \"exports\": {\n    \".\": \"./src/index.ts\",\n    \"./jsx-runtime\": \"./src/jsx-runtime.ts\",\n    \"./jsx-dev-runtime\": \"./src/jsx-runtime.ts\",\n    \"./tools\": \"./src/tools/index.ts\",\n    \"./server\": \"./src/server/index.ts\",\n    \"./observability\": \"./src/observability/index.ts\",\n    \"./pi-plugin\": \"./src/pi-plugin/index.ts\",\n    \"./pi-extension\": \"./src/pi-plugin/extension.ts\",\n    \"./mdx-plugin\": \"./src/mdx-plugin.ts\",\n    \"./baml-plugin\": \"./src/baml-plugin.ts\",\n    \"./dom/renderer\": \"./src/dom/renderer.ts\",\n    \"./serve\": \"./src/server/serve.ts\",\n    \"./scorers\": \"./src/scorers/index.ts\",\n    \"./voice\": \"./src/voice/index.ts\",\n    \"./rag\": \"./src/rag/index.ts\",\n    \"./openapi\": \"./src/openapi/index.ts\"\n  },\n  \"files\": [\n    \"src/\",\n    \"docs/\",\n\nUSER: Your output didn't match the required schema. Validation errors:\n  - reviewer: Invalid input: expected string, received undefined\n  - approved: Invalid input: expected boolean, received undefined\n  - feedback: Invalid input: expected string, received undefined\n\nPlease return valid JSON matching the schema exactly.\n\nYou MUST output ONLY a valid JSON object with exactly these fields and types:\n{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"reviewer\": {\n      \"type\": \"string\"\n    },\n    \"approved\": {\n      \"type\": \"boolean\"\n    },\n    \"feedback\": {\n      \"type\": \"string\"\n    },\n    \"issues\": {\n      \"default\": [],\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"severity\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"critical\",\n              \"major\",\n              \"minor\",\n              \"nit\"\n            ]\n          },\n          \"title\": {\n            \"type\": \"string\"\n          },\n          \"file\": {\n            \"default\": null,\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"description\": {\n            \"type\": \"string\"\n          }\n        },\n        \"required\": [\n          \"severity\",\n          \"title\",\n          \"file\",\n          \"description\"\n        ],\n        \"additionalProperties\": false\n      }\n    }\n  },\n  \"required\": [\n    \"reviewer\",\n    \"approved\",\n    \"feedback\",\n    \"issues\"\n  ],\n  \"additionalProperties\": false\n}\n\nOutput ONLY the JSON object, no other text." agentCommand=claude
