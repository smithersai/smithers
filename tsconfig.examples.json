{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "smithers": ["./packages/smithers/src/examples-entry.ts"],
      "smithers/jsx-runtime": ["./packages/smithers/src/jsx-runtime.ts"],
      "smithers/jsx-dev-runtime": ["./packages/smithers/src/jsx-runtime.ts"],
      "smithers/tools": ["./packages/smithers/src/tools/index.ts"],
      "smithers-orchestrator": ["./packages/smithers/src/examples-entry.ts"],
      "smithers-orchestrator/tools": ["./packages/smithers/src/tools/index.ts"]
    }
  },
  "include": [
    "examples/**/*",
    "packages/smithers/src/examples-entry.ts",
    "packages/smithers/src/**/*"
  ],
  "exclude": [
    "packages/smithers/tests/**/*",
    "packages/smithers/src/pi-plugin/**/*",
    "packages/smithers/src/devtools/**/*"
  ]
}
