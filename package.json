{
  "name": "smithers-orchestrator",
  "version": "0.15.1",
  "description": "AI workflow orchestration with JSX",
  "author": "William Cory",
  "license": "MIT",
  "private": true,
  "module": "packages/smithers/src/index.ts",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    ".smithers"
  ],
  "bin": {
    "smithers": "apps/cli/src/index.ts"
  },
  "exports": {
    ".": "./packages/smithers/src/index.ts",
    "./gateway": "./packages/server/src/gateway.ts",
    "./jsx-runtime": "./packages/smithers/src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./packages/smithers/src/jsx-runtime.ts",
    "./server": "./packages/server/src/index.ts",
    "./observability": "./apps/observability/src/index.ts",
    "./pi-plugin": "./packages/smithers/src/pi-plugin/index.ts",
    "./pi-extension": "./packages/smithers/src/pi-plugin/extension.ts",
    "./mdx-plugin": "./packages/smithers/src/mdx-plugin.ts",
    "./dom/renderer": "./packages/react-reconciler/src/dom/renderer.ts",
    "./serve": "./packages/server/src/serve.ts",
    "./scorers": "./packages/scorers/src/index.ts",
    "./memory": "./packages/memory/src/index.ts",
    "./openapi": "./packages/openapi/src/index.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evmts/smithers.git"
  },
  "homepage": "https://github.com/evmts/smithers#readme",
  "bugs": {
    "url": "https://github.com/evmts/smithers/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "react",
    "jsx",
    "llm",
    "claude",
    "orchestration",
    "workflow",
    "bun"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json --noEmit",
    "lint": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path .gitignore packages/*/src packages/*/tests",
    "lint:fix": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path .gitignore --fix packages/*/src packages/*/tests",
    "cli": "bun run apps/cli/src/index.ts",
    "test": "pnpm -r test",
    "docs": "cd docs && bunx mintlify dev"
  },
  "devDependencies": {
"@tanstack/react-query": "^5.96.2",
    "@types/bun": "latest",
    "@types/diff": "^5.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.28.9",
    "@types/ws": "^8.5.12",
    "oxlint": "^1.59.0",
    "typescript": "~5.9.3"
  }
}
