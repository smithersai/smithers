{
  "name": "smithers-monorepo",
  "version": "0.16.7",
  "description": "AI workflow orchestration with JSX",
  "author": "William Cory",
  "license": "MIT",
  "private": true,
  "module": "packages/smithers/src/index.js",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    ".smithers"
  ],
  "bin": {
    "smithers": "apps/cli/src/index.js"
  },
  "exports": {
    ".": "./packages/smithers/src/index.js",
    "./gateway": "./packages/server/src/gateway.js",
    "./tools": "./packages/smithers/src/tools.js",
    "./jsx-runtime": "./packages/smithers/src/jsx-runtime.js",
    "./jsx-dev-runtime": "./packages/smithers/src/jsx-runtime.js",
    "./server": "./packages/server/src/index.js",
    "./observability": "./apps/observability/src/index.js",
    "./pi-plugin": "./packages/smithers/src/pi-plugin/index.js",
    "./pi-extension": "./packages/smithers/src/pi-plugin/extension.js",
    "./mdx-plugin": "./packages/smithers/src/mdx-plugin.js",
    "./dom/renderer": "./packages/react-reconciler/src/dom/renderer.js",
    "./serve": "./packages/server/src/serve.js",
    "./scorers": "./packages/scorers/src/index.js",
    "./memory": "./packages/memory/src/index.js",
    "./openapi": "./packages/openapi/src/index.js"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evmts/smithers.git"
  },
  "homepage": "https://github.com/evmts/smithers#readme",
  "bugs": {
    "url": "https://github.com/evmts/smithers/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "react",
    "jsx",
    "llm",
    "claude",
    "orchestration",
    "workflow",
    "bun"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json --noEmit",
    "lint": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path .gitignore packages/*/src packages/*/tests",
    "lint:fix": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path .gitignore --fix packages/*/src packages/*/tests",
    "cli": "bun run apps/cli/src/index.js",
    "test": "pnpm -r test",
    "docs": "cd docs && bunx mintlify dev",
    "version": "node scripts/bump.mjs",
    "release": "node scripts/publish.mjs"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.99.1",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.33.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.12",
    "oxlint": "^1.60.0",
    "tsup": "^8.5.1",
    "twitter-api-v2": "^1.29.0",
    "typescript": "~5.9.3"
  }
}
