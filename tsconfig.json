{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "smithers",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "smithers": [
        "./packages/smithers/src/index.js"
      ],
      "smithers/jsx-runtime": [
        "./packages/smithers/src/jsx-runtime.js"
      ],
      "smithers/jsx-dev-runtime": [
        "./packages/smithers/src/jsx-runtime.js"
      ],
      "smithers-orchestrator": [
        "./packages/smithers/src/index.js"
      ],
      "smithers-orchestrator/jsx-runtime": [
        "./packages/smithers/src/jsx-runtime.js"
      ],
      "smithers-orchestrator/jsx-dev-runtime": [
        "./packages/smithers/src/jsx-runtime.js"
      ],
      "smithers-orchestrator/scorers": [
        "./packages/scorers/src/index.js"
      ],
      "@smithers/smithers": [
        "./packages/smithers/src/index.js"
      ],
      "@smithers/smithers/*": [
        "./packages/smithers/src/*.js",
        "./packages/smithers/src/*/index.js"
      ],
      "@smithers/agents": [
        "./packages/agents/src/index.js"
      ],
      "@smithers/agents/*": [
        "./packages/agents/src/*.js",
        "./packages/agents/src/*/index.js"
      ],
      "@smithers/cli": [
        "./apps/cli/src/index.js"
      ],
      "@smithers/cli/*": [
        "./apps/cli/src/*.js",
        "./apps/cli/src/*/index.js"
      ],
      "@smithers/core-react": [
        "./packages/react/src/index.js"
      ],
      "@smithers/core-react/*": [
        "./packages/react/src/*.js",
        "./packages/react/src/*/index.js"
      ],
      "@smithers/db": [
        "./packages/db/src/index.js"
      ],
      "@smithers/db/*": [
        "./packages/db/src/*.js",
        "./packages/db/src/*/index.js"
      ],
      "@smithers/engine": [
        "./packages/engine/src/index.js"
      ],
      "@smithers/engine/*": [
        "./packages/engine/src/*.js",
        "./packages/engine/src/*/index.js"
      ],
      "@smithers/graph": [
        "./packages/graph/src/index.js"
      ],
      "@smithers/graph/*": [
        "./packages/graph/src/*.js",
        "./packages/graph/src/*/index.js"
      ],
      "@smithers/memory": [
        "./packages/memory/src/index.js"
      ],
      "@smithers/memory/*": [
        "./packages/memory/src/*.js",
        "./packages/memory/src/*/index.js"
      ],
      "@smithers/observability": [
        "./apps/observability/src/index.js"
      ],
      "@smithers/observability/*": [
        "./apps/observability/src/*.js",
        "./apps/observability/src/*/index.js"
      ],
      "@smithers/openapi": [
        "./packages/openapi/src/index.js"
      ],
      "@smithers/openapi/*": [
        "./packages/openapi/src/*.js",
        "./packages/openapi/src/*/index.js"
      ],
      "@smithers/components": [
        "./packages/components/src/index.js"
      ],
      "@smithers/components/*": [
        "./packages/components/src/*.js",
        "./packages/components/src/*/index.js"
      ],
      "@smithers/react-reconciler": [
        "./packages/react-reconciler/src/index.js"
      ],
      "@smithers/react-reconciler/*": [
        "./packages/react-reconciler/src/*.js",
        "./packages/react-reconciler/src/*/index.js"
      ],
      "@smithers/sandbox": [
        "./packages/sandbox/src/index.js"
      ],
      "@smithers/sandbox/*": [
        "./packages/sandbox/src/*.js",
        "./packages/sandbox/src/*/index.js"
      ],
      "@smithers/scorers": [
        "./packages/scorers/src/index.js"
      ],
      "@smithers/scorers/*": [
        "./packages/scorers/src/*.js",
        "./packages/scorers/src/*/index.js"
      ],
      "@smithers/server": [
        "./packages/server/src/index.js"
      ],
      "@smithers/server/*": [
        "./packages/server/src/*.js",
        "./packages/server/src/*/index.js"
      ],
      "@smithers/time-travel": [
        "./packages/time-travel/src/index.js"
      ],
      "@smithers/time-travel/*": [
        "./packages/time-travel/src/*.js",
        "./packages/time-travel/src/*/index.js"
      ],
      "@smithers/vcs": [
        "./packages/vcs/src/index.js"
      ],
      "@smithers/vcs/*": [
        "./packages/vcs/src/*.js",
        "./packages/vcs/src/*/index.js"
      ]
    },
    "typeRoots": [
      "./packages/smithers/src/types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "packages/smithers/src/**/*",
    "packages/smithers/tests/**/*",
    "packages/smithers-cli/src/**/*",
    "packages/react/src/**/*",
    "packages/react/tests/**/*"
  ]
}
