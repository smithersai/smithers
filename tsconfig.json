{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "smithers",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "smithers": ["./packages/smithers/src/index.ts"],
      "smithers/jsx-runtime": ["./packages/smithers/src/jsx-runtime.ts"],
      "smithers/jsx-dev-runtime": ["./packages/smithers/src/jsx-runtime.ts"],
      "smithers/tools": ["./packages/tools/src/index.ts"],
      "smithers-orchestrator": ["./packages/smithers/src/index.ts"],
      "smithers-orchestrator/jsx-runtime": ["./packages/smithers/src/jsx-runtime.ts"],
      "smithers-orchestrator/jsx-dev-runtime": ["./packages/smithers/src/jsx-runtime.ts"],
      "smithers-orchestrator/tools": ["./packages/tools/src/index.ts"],
      "smithers-orchestrator/scorers": ["./packages/scorers/src/index.ts"],
      "@smithers/smithers": ["./packages/smithers/src/index.ts"],
      "@smithers/smithers/*": ["./packages/smithers/src/*.ts", "./packages/smithers/src/*/index.ts"],
      "@smithers/agents": ["./packages/agents/src/index.ts"],
      "@smithers/agents/*": ["./packages/agents/src/*.ts", "./packages/agents/src/*/index.ts"],
      "@smithers/cli": ["./apps/cli/src/index.ts"],
      "@smithers/cli/*": ["./apps/cli/src/*.ts", "./apps/cli/src/*/index.ts"],
      "@smithers/core": ["./packages/core/src/index.ts"],
      "@smithers/core/*": [
        "./packages/core/src/*.ts",
        "./packages/core/src/*/index.ts",
        "./packages/core/src/protocol/*.ts",
        "./packages/core/src/protocol/*/index.ts"
      ],
      "@smithers/core/utils/*": ["./packages/core/src/utils/*.ts"],
      "@smithers/core-react": ["./packages/react/src/index.ts"],
      "@smithers/core-react/*": ["./packages/react/src/*.ts", "./packages/react/src/*/index.ts"],
      "@smithers/db": ["./packages/db/src/index.ts"],
      "@smithers/db/*": ["./packages/db/src/*.ts", "./packages/db/src/*/index.ts"],
      "@smithers/engine": ["./packages/engine/src/index.ts"],
      "@smithers/engine/*": ["./packages/engine/src/*.ts", "./packages/engine/src/*/index.ts"],
      "@smithers/graph": ["./packages/graph/src/index.ts"],
      "@smithers/graph/*": ["./packages/graph/src/*.ts", "./packages/graph/src/*/index.ts"],
      "@smithers/memory": ["./packages/memory/src/index.ts"],
      "@smithers/memory/*": ["./packages/memory/src/*.ts", "./packages/memory/src/*/index.ts"],
      "@smithers/observability": ["./packages/observability/src/index.ts"],
      "@smithers/observability/*": ["./packages/observability/src/*.ts", "./packages/observability/src/*/index.ts"],
      "@smithers/openapi": ["./packages/openapi/src/index.ts"],
      "@smithers/openapi/*": ["./packages/openapi/src/*.ts", "./packages/openapi/src/*/index.ts"],
      "@smithers/rag": ["./packages/rag/src/index.ts"],
      "@smithers/rag/*": ["./packages/rag/src/*.ts", "./packages/rag/src/*/index.ts"],
      "@smithers/react": ["./packages/react/src/index.ts"],
      "@smithers/react/*": ["./packages/react/src/*.ts", "./packages/react/src/*/index.ts"],
      "@smithers/react-reconciler": ["./packages/react-reconciler/src/index.ts"],
      "@smithers/react-reconciler/*": ["./packages/react-reconciler/src/*.ts", "./packages/react-reconciler/src/*/index.ts"],
      "@smithers/sandbox": ["./packages/sandbox/src/index.ts"],
      "@smithers/sandbox/*": ["./packages/sandbox/src/*.ts", "./packages/sandbox/src/*/index.ts"],
      "@smithers/scorers": ["./packages/scorers/src/index.ts"],
      "@smithers/scorers/*": ["./packages/scorers/src/*.ts", "./packages/scorers/src/*/index.ts"],
      "@smithers/server": ["./packages/server/src/index.ts"],
      "@smithers/server/*": ["./packages/server/src/*.ts", "./packages/server/src/*/index.ts"],
      "@smithers/time-travel": ["./packages/time-travel/src/index.ts"],
      "@smithers/time-travel/*": ["./packages/time-travel/src/*.ts", "./packages/time-travel/src/*/index.ts"],
      "@smithers/tools": ["./packages/tools/src/index.ts"],
      "@smithers/tools/*": ["./packages/tools/src/*.ts", "./packages/tools/src/*/index.ts"],
      "@smithers/vcs": ["./packages/vcs/src/index.ts"],
      "@smithers/vcs/*": ["./packages/vcs/src/*.ts", "./packages/vcs/src/*/index.ts"],
      "@smithers/voice": ["./packages/voice/src/index.ts"],
      "@smithers/voice/*": ["./packages/voice/src/*.ts", "./packages/voice/src/*/index.ts"]
    },
    "typeRoots": ["./packages/smithers/src/types", "./node_modules/@types"]
  },
  "include": [
    "packages/smithers/src/**/*",
    "packages/smithers/tests/**/*",
    "packages/smithers-cli/src/**/*",
    "packages/core/src/**/*",
    "packages/core/tests/**/*",
    "packages/react/src/**/*",
    "packages/react/tests/**/*"
  ]
}
