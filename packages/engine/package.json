{
  "name": "@smithers/engine",
  "version": "0.0.0",
  "description": "Concrete Smithers workflow execution engine",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/agents": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/memory": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/components": "workspace:*",
    "@smithers/react-reconciler": "workspace:*",
    "@smithers/sandbox": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "@smithers/scorers": "workspace:*",
    "@smithers/time-travel": "workspace:*",
    "@smithers/vcs": "workspace:*",
    "@effect/platform-bun": "^0.89.0",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "react": "^18.3.0 || ^19.0.0",
    "typescript": "~5.9.3"
  }
}
