      "types": "./src/TaskState.ts"
    },
    "./TaskStateMap": {
      "types": "./src/TaskStateMap.ts"
    },
    "./ReadonlyTaskStateMap": {
      "types": "./src/ReadonlyTaskStateMap.ts"
    },
    "./TaskRecord": {
      "types": "./src/TaskRecord.ts"
    },
    "./buildStateKey": {
      "import": "./src/buildStateKey.js",
      "default": "./src/buildStateKey.js",
      "types": "./src/buildStateKey.ts"
    },
    "./parseStateKey": {
      "import": "./src/parseStateKey.js",
      "default": "./src/parseStateKey.js",
      "types": "./src/parseStateKey.ts"
    },
    "./cloneTaskStateMap": {
      "import": "./src/cloneTaskStateMap.js",
      "default": "./src/cloneTaskStateMap.js",
      "types": "./src/cloneTaskStateMap.ts"
    },
    "./isTerminalState": {
      "import": "./src/isTerminalState.js",
