    "./retryScheduleDelayMs": {
      "import": "./src/retryScheduleDelayMs.js",
      "default": "./src/retryScheduleDelayMs.js",
      "types": "./src/retryScheduleDelayMs.ts"
    },
    "./computeRetryDelayMs": {
      "import": "./src/computeRetryDelayMs.js",
      "default": "./src/computeRetryDelayMs.js",
      "types": "./src/computeRetryDelayMs.ts"
    },
    "./nowMs": {
      "import": "./src/nowMs.js",
      "default": "./src/nowMs.js",
      "types": "./src/nowMs.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
