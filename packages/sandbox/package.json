{
  "name": "@smithers/sandbox",
  "version": "0.0.0",
  "description": "Sandbox bundle, execution, and transport integration for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/components": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/scheduler": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
