{
  "name": "@smithers-orchestrator/errors",
  "version": "0.16.0",
  "description": "Error types, tagged errors, and error utilities for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsup --dts-only"
  },
  "dependencies": {
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
