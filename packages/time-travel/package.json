{
  "name": "@smithers-orchestrator/time-travel",
  "version": "0.16.8",
  "description": "Smithers snapshots, diffs, forks, replay, timelines, and VCS-tagged run history",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./snapshot": {
      "types": "./src/index.d.ts",
      "import": "./src/snapshot/index.js",
      "default": "./src/snapshot/index.js"
    },
    "./fork": {
      "types": "./src/index.d.ts",
      "import": "./src/fork/index.js",
      "default": "./src/fork/index.js"
    },
    "./timeline": {
      "types": "./src/index.d.ts",
      "import": "./src/timeline/index.js",
      "default": "./src/timeline/index.js"
    },
    "./vcs-version": {
      "types": "./src/index.d.ts",
      "import": "./src/vcs-version/index.js",
      "default": "./src/vcs-version/index.js"
    },
    "./metrics": {
      "types": "./src/index.d.ts",
      "import": "./src/metrics.js",
      "default": "./src/metrics.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "bun --bun tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@smithers-orchestrator/db": "workspace:*",
    "@smithers-orchestrator/driver": "workspace:*",
    "@smithers-orchestrator/errors": "workspace:*",
    "@smithers-orchestrator/graph": "workspace:*",
    "@smithers-orchestrator/observability": "workspace:*",
    "@smithers-orchestrator/scheduler": "workspace:*",
    "@smithers-orchestrator/vcs": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
