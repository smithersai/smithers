{
  "name": "@smithers/agents",
  "version": "0.0.0",
  "description": "AI SDK and CLI agent adapters for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./BaseCliAgent": {
      "import": "./src/BaseCliAgent/index.js",
      "default": "./src/BaseCliAgent/index.js",
      "types": "./src/BaseCliAgent/index.ts"
    },
    "./agent-contract": {
      "import": "./src/agent-contract/index.js",
      "default": "./src/agent-contract/index.js",
      "types": "./src/agent-contract/index.ts"
    },
    "./diagnostics": {
      "import": "./src/diagnostics/index.js",
      "default": "./src/diagnostics/index.js",
      "types": "./src/diagnostics/index.ts"
    },
    "./capability-registry": {
      "import": "./src/capability-registry/index.js",
      "default": "./src/capability-registry/index.js",
      "types": "./src/capability-registry/index.ts"
    },
    "./cli-capabilities": {
      "import": "./src/cli-capabilities/index.js",
      "default": "./src/cli-capabilities/index.js",
      "types": "./src/cli-capabilities/index.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.36",
    "@ai-sdk/openai": "^3.0.41",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "ai": "^6.0.69",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
