{
  "name": "@smithers-orchestrator/db",
  "version": "0.16.9",
  "description": "SQLite and Drizzle persistence adapter for Smithers workflows",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/experimental": "^0.60.0",
    "@effect/sql": "^0.51.0",
    "@smithers-orchestrator/driver": "workspace:*",
    "@smithers-orchestrator/errors": "workspace:*",
    "@smithers-orchestrator/graph": "workspace:*",
    "@smithers-orchestrator/observability": "workspace:*",
    "@smithers-orchestrator/scheduler": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
