{
  "name": "@smithers/db",
  "version": "0.0.0",
  "description": "SQLite and Drizzle persistence adapter for Smithers workflows",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/core": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/runtime": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@effect/experimental": "^0.58.0",
    "@effect/sql": "^0.51.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
