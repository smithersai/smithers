{
  "name": "@smithers/components",
  "version": "0.0.0",
  "description": "React components for Smithers workflows",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/agents": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/durables": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/memory": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/react-reconciler": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "@smithers/scorers": "workspace:*",

    "bippy": "^0.5.32",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
