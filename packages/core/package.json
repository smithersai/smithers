      "types": "./src/protocol/RunOptions.ts",
      "default": "./src/protocol/RunOptions.ts"
    },
    "./RunResult": {
      "types": "./src/protocol/RunResult.ts",
      "default": "./src/protocol/RunResult.ts"
    },
    "./RunStatus": {
      "types": "./src/protocol/RunStatus.ts",
      "default": "./src/protocol/RunStatus.ts"
