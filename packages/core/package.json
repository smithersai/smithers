    },
    "./durables": {
      "types": "./src/durables.ts",
      "default": "./src/durables.ts"
    },
    "./devtools": {
      "types": "./src/devtools.ts",
      "default": "./src/devtools.ts"
    },
    "./driver": {
      "types": "./src/driver.ts",
      "default": "./src/driver.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./execution": {
      "types": "./src/execution.ts",
      "default": "./src/execution.ts"
    },
    "./graph": {
      "types": "./src/graph.ts",
      "default": "./src/graph.ts"
    },
    "./interop": {
      "types": "./src/interop.ts",
      "default": "./src/interop.ts"
    },
    "./observability": {
      "types": "./src/observability/index.ts",
      "default": "./src/observability/index.ts"
    },
    "./persistence": {
      "types": "./src/persistence/index.ts",
