  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/graph": "workspace:*",
    "effect": "^3.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
