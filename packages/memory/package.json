{
  "name": "@smithers/memory",
  "version": "0.0.0",
  "description": "Persistent and semantic memory services for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./store": {
      "import": "./src/store/index.js",
      "default": "./src/store/index.js",
      "types": "./src/store/index.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
