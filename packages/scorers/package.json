{
  "name": "@smithers-orchestrator/scorers",
  "version": "0.16.8",
  "description": "Smithers scorer definitions, execution, aggregation, and persistence helpers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "bun --bun tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers-orchestrator/agents": "workspace:*",
    "@smithers-orchestrator/db": "workspace:*",
    "@smithers-orchestrator/driver": "workspace:*",
    "@smithers-orchestrator/errors": "workspace:*",
    "@smithers-orchestrator/observability": "workspace:*",
    "@smithers-orchestrator/scheduler": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
