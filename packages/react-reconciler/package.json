{
  "name": "@smithers-orchestrator/react-reconciler",
  "version": "0.16.8",
  "description": "Custom React reconciler that renders Smithers host trees",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./context": {
      "types": "./src/index.d.ts",
      "import": "./src/context.js",
      "default": "./src/context.js"
    },
    "./devtools": {
      "types": "./src/index.d.ts",
      "import": "./src/devtools/index.js",
      "default": "./src/devtools/index.js"
    },
    "./devtools/preload": {
      "import": "./src/devtools/preload.js",
      "default": "./src/devtools/preload.js"
    },
    "./driver": {
      "types": "./src/index.d.ts",
      "import": "./src/driver.js",
      "default": "./src/driver.js"
    },
    "./jsx-runtime": {
      "types": "./src/index.d.ts",
      "import": "./src/jsx-runtime.js",
      "default": "./src/jsx-runtime.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "rm -f src/index.d.ts && bun --bun tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers-orchestrator/devtools": "workspace:*",
    "@smithers-orchestrator/driver": "workspace:*",
    "@smithers-orchestrator/errors": "workspace:*",
    "@smithers-orchestrator/graph": "workspace:*",
    "bippy": "^0.5.39",
    "react": "^19.2.5",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
