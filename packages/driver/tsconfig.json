{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "smithers",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": [
      "bun-types"
    ],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "smithers/jsx-runtime": ["../smithers/src/jsx-runtime.ts"],
      "smithers/jsx-dev-runtime": ["../smithers/src/jsx-runtime.ts"],
      "@smithers/react-reconciler/*": ["../react-reconciler/src/*.ts"],
      "@smithers/scheduler/*": ["../scheduler/src/*.ts"],
      "@smithers/graph": ["../graph/src/index.ts"],
      "@smithers/graph/*": ["../graph/src/*.ts"],
      "@smithers/errors/*": ["../errors/src/*.ts"],
      "@smithers/db/*": ["../db/src/*.ts"],
      "@smithers/observability/*": ["../../apps/observability/src/*.ts"]
    }
  },
  "include": [
    "src/**/*"
  ]
}
