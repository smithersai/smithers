{
  "name": "@smithers/runtime",
  "version": "0.0.0",
  "description": "Concrete Effect runtime and platform helpers for Smithers packages",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/workflow": "^0.18.0",
    "@smithers/core": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
