{
  "name": "@smithers/devtools",
  "version": "0.0.0",
  "description": "Devtools and debugging utilities for Smithers workflow inspection",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./DevToolsEventBus": {
      "types": "./src/DevToolsEventBus.ts"
    },
    "./DevToolsEventHandler": {
      "types": "./src/DevToolsEventHandler.ts"
    },
    "./DevToolsNode": {
      "types": "./src/DevToolsNode.ts"
    },
    "./DevToolsRunStore": {
      "import": "./src/DevToolsRunStore.js",
      "default": "./src/DevToolsRunStore.js",
      "types": "./src/DevToolsRunStore.ts"
    },
    "./DevToolsRunStoreOptions": {
      "types": "./src/DevToolsRunStoreOptions.ts"
    },
    "./DevToolsSnapshot": {
      "types": "./src/DevToolsSnapshot.ts"
    },
    "./RunExecutionState": {
      "types": "./src/RunExecutionState.ts"
    },
    "./SMITHERS_NODE_ICONS": {
      "import": "./src/SMITHERS_NODE_ICONS.js",
      "default": "./src/SMITHERS_NODE_ICONS.js",
      "types": "./src/SMITHERS_NODE_ICONS.ts"
    },
    "./SmithersDevToolsCore": {
      "import": "./src/SmithersDevToolsCore.js",
      "default": "./src/SmithersDevToolsCore.js",
      "types": "./src/SmithersDevToolsCore.ts"
    },
    "./SmithersDevToolsOptions": {
      "types": "./src/SmithersDevToolsOptions.ts"
    },
    "./SmithersNodeType": {
      "types": "./src/SmithersNodeType.ts"
    },
    "./TaskExecutionState": {
      "types": "./src/TaskExecutionState.ts"
    },
    "./buildSnapshot": {
      "import": "./src/buildSnapshot.js",
      "default": "./src/buildSnapshot.js",
      "types": "./src/buildSnapshot.ts"
    },
    "./collectTasks": {
      "import": "./src/collectTasks.js",
      "default": "./src/collectTasks.js",
      "types": "./src/collectTasks.ts"
    },
    "./countNodes": {
      "import": "./src/countNodes.js",
      "default": "./src/countNodes.js",
      "types": "./src/countNodes.ts"
    },
    "./findNodeById": {
      "import": "./src/findNodeById.js",
      "default": "./src/findNodeById.js",
      "types": "./src/findNodeById.ts"
    },
    "./printTree": {
      "import": "./src/printTree.js",
      "default": "./src/printTree.js",
      "types": "./src/printTree.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
