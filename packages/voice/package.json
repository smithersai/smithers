{
  "name": "@smithers/voice",
  "version": "0.0.0",
  "description": "Voice provider contracts and realtime voice integrations for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "ai": "^6.0.69",
    "effect": "^3.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
